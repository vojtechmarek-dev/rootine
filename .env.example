DATABASE_URL="postgres://user:password@host:port/db-name"
AUTH_SECRET="rand" # running `openssl rand -hex 32` helps
GOOGLE_CLIENT_ID="client_id"
GOOGLE_CLIENT_SECRET="secret"
# Web Push (VAPID): npx web-push generate-vapid-keys
PUBLIC_VAPID_PUBLIC_KEY="vapid_public_key"
VAPID_PRIVATE_KEY="vapid_private_key"
VAPID_SUBJECT="mailto:you@example.com"
CRON_SECRET="rand" # protects /api/cron/reminders; Vercel sends it automatically
